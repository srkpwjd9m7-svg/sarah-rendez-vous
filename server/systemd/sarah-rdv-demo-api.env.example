# Env file for sarah-rdv-demo-api.service.
# Copy to /etc/sarah-rdv-demo-api.env (chmod 600 root:root).
#
# IMPORTANT: ACCESS_CODE here is NOT secret. It must match the DEMO_CODE
# constant baked into the frontend (index.html), which auto-fills it in
# localStorage when the page is opened under /rdv-demo/. The demo is meant
# to be public — anyone with the URL can use the app.

ACCESS_CODE=demo-public
DATA_DIR=/var/lib/sarah-rdv-demo
PORT=9093
HOST=127.0.0.1
MEDIA_URL_PREFIX=/rdv-demo/media

# Required by seed-demo.js as an explicit opt-in safety belt.
DEMO_SEED=1
